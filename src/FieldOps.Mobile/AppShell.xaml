<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FieldOps.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:FieldOps.Mobile.Pages"
    Title="FieldOps Mobile"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate pages:DashboardPage}"
            Route="Dashboard" />

        <ShellContent
            Title="Work Orders"
            ContentTemplate="{DataTemplate pages:WorkOrdersPage}"
            Route="WorkOrders" />
    </TabBar>

</Shell>
