<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FieldOps.Mobile.ViewModels"
             x:Class="FieldOps.Mobile.Pages.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Field Operations Overview"
                   Style="{StaticResource Headline}"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label Text="Track assigned work orders and sync local changes."
                   Style="{StaticResource SubHeadline}"
                   TextColor="{StaticResource Gray500}" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Total" Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding TotalWorkOrders}" Style="{StaticResource CardValueStyle}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SummaryCardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Open" Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding OpenCount}" Style="{StaticResource CardValueStyle}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="In Progress" Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding InProgressCount}" Style="{StaticResource CardValueStyle}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SummaryCardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Completed" Style="{StaticResource CardLabelStyle}" />
                        <Label Text="{Binding CompletedCount}" Style="{StaticResource CardValueStyle}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource SummaryCardAccentStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Pending Sync" Style="{StaticResource CardLabelStyle}" TextColor="White" />
                        <Label Text="{Binding PendingSyncCount}" Style="{StaticResource CardValueStyle}" TextColor="White" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border Style="{StaticResource InfoPanelStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Last Sync" FontAttributes="Bold" />
                    <Label Text="{Binding LastSyncDisplay}" TextColor="{StaticResource Gray600}" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Sync Now"
                    Command="{Binding SyncNowCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

            <Border IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                    BackgroundColor="#FEE2E2"
                    Stroke="#FCA5A5"
                    Padding="12">
                <Label Text="{Binding ErrorMessage}" TextColor="#991B1B" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
